---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const toSlug = (value: string) =>
	value
		.toLowerCase()
		.trim()
		.replace(/&/g, 'and')
		.replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
		.replace(/^-|-$/g, '');

const focusCategories = [
	{ label: 'Security', slug: 'security' },
	{ label: 'Agent', slug: 'agent' },
	{ label: 'Network', slug: 'network' },
	{ label: 'Development', slug: 'development' },
];

const tagDirectoryMap: Record<string, string> = {
	security: 'security',
	'面经': 'security',
	tool: 'security',
	agent: 'agent',
	network: 'network',
	web: 'network',
	http: 'network',
	code: 'development',
	'题解': 'development',
	development: 'development',
};

const getDirectorySlugs = (tags: string[]) => {
	const slugs = tags.map((tag) => tagDirectoryMap[toSlug(tag)]).filter(Boolean);
	return [...new Set(slugs.length > 0 ? slugs : ['development'])];
};

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.map((post) => ({
		...post,
		categories: getDirectorySlugs(post.data.tags),
	}));

const profile = {
	name: 'Yida',
	role: 'Software Engineer & Research Explorer',
	intro:
		'专注于构建可靠、可扩展、易理解的系统，也记录工程实践、机器学习和个人研究中的思考。',
	github: 'https://github.com/Yodasama',
	email: 'yidaaa2269@163.com',
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="articles-page">
		<div class="site-shell">
			<aside class="profile-panel" aria-label="个人信息">
				<div class="profile-main">
					<img class="avatar" src="/images/panda.JPG" width="180" height="180" alt={`${profile.name} avatar`} />
					<h1>{profile.name}</h1>
					<p>{profile.role}</p>
				</div>

				<section class="panel-section">
					<h2>About Me</h2>
					<p>{profile.intro}</p>
				</section>

				<section class="panel-section">
					<h2>Focus</h2>
					<ul class="focus-list">
						{
							focusCategories.map((category) => (
								<li>
									<button class="focus-button" type="button" data-filter={category.slug}>
										<span>{category.label}</span>
									</button>
								</li>
							))
						}
					</ul>
				</section>

				<section class="panel-section connect-section">
					<h2>Connect</h2>
					<div class="contact-list">
						<a href={profile.github} target="_blank" rel="noreferrer">
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path
										d="M12 2.5a9.5 9.5 0 0 0-3 18.52c.48.08.66-.2.66-.46v-1.7c-2.7.6-3.27-1.16-3.27-1.16-.44-1.12-1.08-1.42-1.08-1.42-.88-.6.07-.6.07-.6.98.07 1.5 1.02 1.5 1.02.88 1.5 2.3 1.06 2.86.8.09-.64.34-1.06.62-1.3-2.16-.25-4.43-1.08-4.43-4.8 0-1.06.38-1.93 1-2.61-.1-.25-.43-1.24.1-2.58 0 0 .82-.26 2.67 1a9.2 9.2 0 0 1 4.86 0c1.85-1.26 2.66-1 2.66-1 .54 1.34.2 2.33.1 2.58.63.68 1 1.55 1 2.61 0 3.73-2.27 4.55-4.44 4.79.35.3.67.9.67 1.82v2.7c0 .26.17.55.67.46A9.5 9.5 0 0 0 12 2.5Z"
									/>
								</svg>
							</span>
							<span>
								<strong>GitHub</strong>
								<small>github.com/Yodasama</small>
							</span>
						</a>
						<a href={`mailto:${profile.email}`}>
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path d="M4 6.5h16v11H4z" />
									<path d="m4 7 8 6 8-6" />
								</svg>
							</span>
							<span>
								<strong>Email</strong>
								<small>{profile.email}</small>
							</span>
						</a>
					</div>
				</section>
			</aside>

			<main class="content-area">
				<nav class="top-nav" aria-label="主导航">
					<div class="nav-links">
						<a href="/">Home</a>
						<a class="active" href="/blog">Articles</a>
						<a href="/projects">Projects</a>
						<a href="/about">About</a>
					</div>
					<div class="nav-tools">
						<button class="theme-toggle" type="button" aria-label="切换明暗主题">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="M12 3v2" />
								<path d="M12 19v2" />
								<path d="m4.22 4.22 1.42 1.42" />
								<path d="m18.36 18.36 1.42 1.42" />
								<path d="M3 12h2" />
								<path d="M19 12h2" />
								<path d="m4.22 19.78 1.42-1.42" />
								<path d="m18.36 5.64 1.42-1.42" />
								<circle cx="12" cy="12" r="4" />
							</svg>
						</button>
						<form class="search-form" action="/blog" method="get" role="search">
							<label class="sr-only" for="site-search">搜索文章</label>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="m21 21-4.35-4.35" />
								<circle cx="11" cy="11" r="7" />
							</svg>
							<input id="site-search" name="q" type="search" placeholder="Search articles" />
						</form>
					</div>
				</nav>

				<section class="articles-panel" aria-labelledby="articles-title">
					<div class="articles-heading">
						<div>
							<p>All Posts</p>
							<h2 id="articles-title">Articles</h2>
						</div>
						<span>{posts.length} posts</span>
					</div>

					<div class="articles-scroll">
						<div class="article-stack">
							{
								posts.map((post) => (
									<a class="article-card" href={`/blog/${post.id}/`} data-categories={post.categories.join(' ')}>
										<div class="article-card-main">
											<h3>{post.data.title}</h3>
											<p>{post.data.summary}</p>
											<div class="tag-list">
												{post.data.tags.map((tag) => (
													<span>{tag}</span>
												))}
											</div>
										</div>
										<div class="article-card-meta">
											<FormattedDate date={post.data.date} />
											<small>6 min read</small>
										</div>
									</a>
								))
							}
						</div>
						<p class="empty-state" data-empty-state>这个分类下暂时还没有文章。</p>
					</div>
				</section>
			</main>
		</div>

		<script>
			const themeButton = document.querySelector('.theme-toggle');
			const savedTheme = localStorage.getItem('theme');

			if (savedTheme === 'dark') {
				document.body.classList.add('dark-mode');
			}

			themeButton?.addEventListener('click', () => {
				document.body.classList.toggle('dark-mode');
				localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
			});

			const filterButtons = [...document.querySelectorAll('.focus-button')];
			const articleCards = [...document.querySelectorAll('.article-card')];
			const emptyState = document.querySelector('[data-empty-state]');

			function applyFilter(slug) {
				const activeButton = filterButtons.find((button) => button.dataset.filter === slug);
				const activeSlug = activeButton?.dataset.filter ?? 'all';

				filterButtons.forEach((button) => {
					button.classList.toggle('active', button.dataset.filter === activeSlug);
				});

				const showCard = (card) =>
					activeSlug === 'all' || (card.dataset.categories ?? '').split(' ').includes(activeSlug);
				const visibleCards = articleCards.filter(showCard);

				articleCards.forEach((card) => {
					card.hidden = !showCard(card);
				});
				if (emptyState) emptyState.hidden = visibleCards.length > 0;

				const url = new URL(window.location.href);
				if (activeSlug === 'all') {
					url.searchParams.delete('focus');
				} else {
					url.searchParams.set('focus', activeSlug);
				}
				window.history.replaceState({}, '', url);
			}

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => applyFilter(button.dataset.filter ?? 'all'));
			});

			applyFilter(new URLSearchParams(window.location.search).get('focus') ?? 'all');
		</script>
	</body>
</html>

<style>
	:global(body.articles-page) {
		min-height: 100vh;
		background:
			radial-gradient(circle at 78% 8%, rgba(72, 122, 255, 0.12), transparent 34rem),
			linear-gradient(90deg, #f5f7fb 0, #f5f7fb 19.5rem, #ffffff 19.5rem);
		color: #111827;
		font-size: 16px;
		line-height: 1.5;
		transition:
			background 180ms ease,
			color 180ms ease;
	}

	:global(body.articles-page.dark-mode) {
		background:
			radial-gradient(circle at 78% 8%, rgba(96, 165, 250, 0.16), transparent 34rem),
			linear-gradient(90deg, #0f172a 0, #0f172a 19.5rem, #111827 19.5rem);
		color: #e5e7eb;
	}

	:global(body.articles-page a) {
		color: inherit;
		text-decoration: none;
	}

	.site-shell,
	.site-shell * {
		box-sizing: border-box;
	}

	.site-shell {
		display: grid;
		grid-template-columns: 19.5rem minmax(0, 1fr);
		min-height: 100svh;
	}

	.profile-panel {
		position: sticky;
		top: 0;
		display: flex;
		flex-direction: column;
		gap: 1.35rem;
		height: 100svh;
		padding: 2rem;
		border-right: 1px solid rgba(148, 163, 184, 0.22);
		overflow: clip;
	}

	.profile-main {
		text-align: center;
	}

	.avatar {
		width: 7.5rem;
		height: 7.5rem;
		margin: 0 auto 1rem;
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 999px;
		box-shadow: 0 20px 54px rgba(15, 23, 42, 0.18);
		object-fit: cover;
		object-position: center;
	}

	.profile-main h1 {
		margin: 0;
		color: #030712;
		font-size: 1.55rem;
		line-height: 1.1;
	}

	.profile-main p,
	.panel-section p,
	.article-card p {
		color: #4b5563;
	}

	.profile-main p {
		margin: 0.7rem 0 0;
		font-size: 0.92rem;
	}

	.panel-section {
		padding-top: 1.15rem;
		border-top: 1px solid rgba(148, 163, 184, 0.28);
	}

	.connect-section {
		margin-top: auto;
	}

	.panel-section h2 {
		margin: 0 0 0.65rem;
		color: #6b7280;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.panel-section p {
		margin: 0;
		font-size: 0.88rem;
	}

	.focus-list,
	.contact-list {
		display: grid;
		gap: 0.72rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.contact-list a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #111827;
		font-size: 0.88rem;
	}

	.contact-icon,
	.theme-toggle,
	.search-form svg {
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		color: #4b5563;
	}

	.contact-icon svg,
	.theme-toggle svg,
	.search-form svg {
		width: 1.05rem;
		height: 1.05rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.focus-button {
		display: flex;
		align-items: center;
		width: 100%;
		min-height: 2.35rem;
		justify-content: flex-start;
		padding: 0 0.7rem;
		border: 1px solid transparent;
		border-radius: 0.8rem;
		background: transparent;
		color: #111827;
		cursor: pointer;
		font: inherit;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.focus-button:hover,
	.focus-button.active {
		border-color: rgba(209, 213, 219, 0.78);
		background: rgba(255, 255, 255, 0.74);
		transform: translateX(2px);
	}

	.focus-button:focus {
		outline: none;
	}

	.focus-button:focus-visible {
		outline: 2px solid #2563eb;
		outline-offset: 2px;
	}

	.contact-list a {
		border-radius: 0.75rem;
		transition:
			background 180ms ease,
			transform 180ms ease;
	}

	.contact-list a:hover {
		background: rgba(255, 255, 255, 0.66);
		transform: translateX(2px);
	}

	.contact-list strong,
	.contact-list small {
		display: block;
	}

	.contact-list small {
		color: #6b7280;
		font-size: 0.78rem;
	}

	.content-area {
		display: grid;
		grid-template-rows: 2.55rem minmax(0, 1fr);
		gap: 0.9rem;
		width: 100%;
		max-width: 78rem;
		height: 100svh;
		margin: 0 auto;
		padding: 1rem 2rem 1.25rem;
		overflow: hidden;
	}

	.top-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-width: 0;
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.65rem;
		min-width: 0;
	}

	.nav-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.35rem;
		padding: 0 0.95rem;
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 700;
		transition:
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-links a.active,
	.nav-links a:hover {
		background: rgba(243, 244, 246, 0.94);
		box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.12);
	}

	.nav-tools {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		flex: 0 0 auto;
	}

	.theme-toggle,
	.search-form {
		border: 1px solid rgba(209, 213, 219, 0.86);
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
	}

	.theme-toggle {
		width: 2.35rem;
		height: 2.35rem;
		padding: 0;
		border-radius: 999px;
		cursor: pointer;
	}

	.search-form {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		width: clamp(12rem, 20vw, 18rem);
		height: 2.35rem;
		padding: 0 0.85rem;
		border-radius: 999px;
	}

	.search-form input {
		width: 100%;
		min-width: 0;
		border: 0;
		outline: 0;
		background: transparent;
		color: #111827;
		font: inherit;
		font-size: 0.86rem;
	}

	.search-form input::placeholder {
		color: #9ca3af;
	}

	.articles-panel {
		display: flex;
		flex-direction: column;
		min-height: 0;
		border: 1px solid rgba(226, 232, 240, 0.92);
		border-radius: 1.35rem;
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 22px 80px rgba(15, 23, 42, 0.06);
		overflow: hidden;
	}

	.articles-heading {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.35rem 1.45rem 1rem;
		border-bottom: 1px solid rgba(226, 232, 240, 0.9);
	}

	.articles-heading p {
		margin: 0 0 0.2rem;
		color: #64748b;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.articles-heading h2 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(1.8rem, 3vw, 3rem);
		line-height: 1;
	}

	.articles-heading span {
		color: #64748b;
		font-size: 0.86rem;
		font-weight: 700;
	}

	.articles-scroll {
		flex: 1;
		min-height: 0;
		overflow-y: auto;
		padding: 1rem 1.05rem 1.25rem 1.45rem;
		scrollbar-gutter: stable;
	}

	.article-stack {
		display: grid;
		gap: 0.85rem;
	}

	.article-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: start;
		padding: 1rem;
		border: 1px solid rgba(226, 232, 240, 0.92);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.72);
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.article-card:hover {
		border-color: rgba(148, 163, 184, 0.6);
		box-shadow: 0 14px 38px rgba(15, 23, 42, 0.08);
		transform: translateY(-1px);
	}

	.article-card[hidden],
	.empty-state[hidden] {
		display: none;
	}

	.article-card h3 {
		margin: 0;
		color: #0f172a;
		font-size: 1.05rem;
		line-height: 1.25;
	}

	.article-card p {
		display: -webkit-box;
		margin: 0.42rem 0 0;
		overflow: hidden;
		font-size: 0.88rem;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.72rem;
	}

	.tag-list span {
		padding: 0.16rem 0.55rem;
		border-radius: 999px;
		background: #f3f4f6;
		color: #4b5563;
		font-size: 0.72rem;
		font-weight: 700;
	}

	.article-card-meta {
		display: grid;
		justify-items: end;
		gap: 0.24rem;
		color: #64748b;
		font-size: 0.78rem;
		white-space: nowrap;
	}

	.article-card-meta small {
		color: #94a3b8;
		font-size: 0.72rem;
	}

	.empty-state {
		display: grid;
		place-items: center;
		min-height: 12rem;
		margin: 0;
		border: 1px dashed rgba(148, 163, 184, 0.5);
		border-radius: 1rem;
		color: #64748b;
		font-size: 0.86rem;
		text-align: center;
	}

	:global(body.articles-page.dark-mode) .profile-main h1,
	:global(body.articles-page.dark-mode) .focus-button,
	:global(body.articles-page.dark-mode) .contact-list a,
	:global(body.articles-page.dark-mode) .articles-heading h2,
	:global(body.articles-page.dark-mode) .article-card h3 {
		color: #f9fafb;
	}

	:global(body.articles-page.dark-mode) .profile-main p,
	:global(body.articles-page.dark-mode) .panel-section p,
	:global(body.articles-page.dark-mode) .article-card p,
	:global(body.articles-page.dark-mode) .articles-heading p,
	:global(body.articles-page.dark-mode) .articles-heading span,
	:global(body.articles-page.dark-mode) .contact-list small,
	:global(body.articles-page.dark-mode) .empty-state {
		color: #cbd5e1;
	}

	:global(body.articles-page.dark-mode) .articles-panel,
	:global(body.articles-page.dark-mode) .theme-toggle,
	:global(body.articles-page.dark-mode) .search-form {
		border-color: rgba(71, 85, 105, 0.8);
		background: rgba(15, 23, 42, 0.78);
	}

	:global(body.articles-page.dark-mode) .article-card {
		border-color: rgba(71, 85, 105, 0.72);
		background: rgba(15, 23, 42, 0.52);
	}

	:global(body.articles-page.dark-mode) .nav-links a.active,
	:global(body.articles-page.dark-mode) .nav-links a:hover,
	:global(body.articles-page.dark-mode) .focus-button:hover,
	:global(body.articles-page.dark-mode) .focus-button.active,
	:global(body.articles-page.dark-mode) .tag-list span {
		background: rgba(30, 41, 59, 0.86);
		color: #e5e7eb;
	}

	:global(body.articles-page.dark-mode) .search-form input {
		color: #f9fafb;
	}

	:global(body.articles-page.dark-mode) .articles-heading,
	:global(body.articles-page.dark-mode) .empty-state {
		border-color: rgba(71, 85, 105, 0.8);
	}

	@media (max-width: 1180px) {
		.site-shell {
			grid-template-columns: 17rem minmax(0, 1fr);
		}

		:global(body.articles-page) {
			background:
				radial-gradient(circle at 78% 8%, rgba(72, 122, 255, 0.12), transparent 34rem),
				linear-gradient(90deg, #f5f7fb 0, #f5f7fb 17rem, #ffffff 17rem);
		}

		.content-area {
			padding-inline: 1.35rem;
		}

		.search-form {
			width: 13rem;
		}
	}

	@media (max-width: 900px) {
		:global(body.articles-page),
