---
import BaseHead from '../components/BaseHead.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import ProjectShell from '../components/projects/ProjectShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { featuredProjects, projectCategories, projects } from '../data/projects';

const allProjects = projects.filter((project) => !project.featured);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="project-system-page">
		<ProjectShell>
			<section class="project-hero" aria-labelledby="projects-title">
				<p class="eyebrow">Engineering Portfolio</p>
				<h1 id="projects-title">Projects</h1>
				<p>
					A curated set of AI, security, research, and web engineering projects. Each project is written as a technical artifact: what it does, how it is built, and what I learned from shipping it.
				</p>
				<div class="filter-strip" aria-label="Project categories">
					<button type="button" class="active" data-project-filter="all">All</button>
					{projectCategories.map((category) => <button type="button" data-project-filter={category}>{category}</button>)}
				</div>
			</section>

			<section class="project-section" aria-labelledby="featured-title">
				<div class="section-heading">
					<div>
						<p class="eyebrow">Selected Work</p>
						<h2 id="featured-title">Featured Projects</h2>
					</div>
					<p>{featuredProjects.length} featured</p>
				</div>
				<div class="featured-grid">
					{featuredProjects.map((project) => <ProjectCard project={project} featured />)}
				</div>
			</section>

			<section class="project-section" aria-labelledby="all-projects-title">
				<div class="section-heading">
					<div>
						<p class="eyebrow">Index</p>
						<h2 id="all-projects-title">All Projects</h2>
					</div>
					<p>{projects.length} projects</p>
				</div>
				<div class="all-projects-grid">
					{allProjects.map((project) => <ProjectCard project={project} />)}
				</div>
			</section>
		</ProjectShell>

		<script>
			const filterButtons = [...document.querySelectorAll('[data-project-filter]')];
			const projectCards = [...document.querySelectorAll('.project-card')];
			const searchInput = document.querySelector('[data-project-search]');

			function applyProjectFilters() {
				const activeButton = filterButtons.find((button) => button.classList.contains('active'));
				const activeFilter = activeButton?.dataset.projectFilter ?? 'all';
				const query = searchInput?.value?.toLowerCase().trim() ?? '';

				projectCards.forEach((card) => {
					const categories = card.dataset.categories ?? '';
					const text = card.textContent?.toLowerCase() ?? '';
					const categoryMatch = activeFilter === 'all' || categories.includes(activeFilter);
					const queryMatch = !query || text.includes(query);
					card.hidden = !(categoryMatch && queryMatch);
				});
			}

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((candidate) => candidate.classList.toggle('active', candidate === button));
					applyProjectFilters();
				});
			});

			searchInput?.addEventListener('input', applyProjectFilters);
		</script>
	</body>
</html>
