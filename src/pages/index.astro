---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import HeroImage from '../assets/hero/background.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const toSlug = (value: string) =>
	value
		.toLowerCase()
		.trim()
		.replace(/&/g, 'and')
		.replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
		.replace(/^-|-$/g, '');

const focusCategories = [
	{ label: 'Security', slug: 'security' },
	{ label: 'Agent', slug: 'agent' },
	{ label: 'Network', slug: 'network' },
	{ label: 'Development', slug: 'development' },
];

const tagDirectoryMap: Record<string, string> = {
	security: 'security',
	'面经': 'security',
	tool: 'security',
	agent: 'agent',
	network: 'network',
	web: 'network',
	http: 'network',
	code: 'development',
	'题解': 'development',
	development: 'development',
};

const getDirectorySlugs = (tags: string[]) => {
	const slugs = tags.map((tag) => tagDirectoryMap[toSlug(tag)]).filter(Boolean);
	return [...new Set(slugs.length > 0 ? slugs : ['development'])];
};

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((post) => ({
		...post,
		categories: getDirectorySlugs(post.data.tags),
	}));
const homePosts = posts.slice(0, 4);

const profile = {
	name: 'Yida',
	role: 'Software Engineer & Research Explorer',
	intro:
		'专注于构建可靠、可扩展、易理解的系统，也记录工程实践、机器学习和个人研究中的思考。',
	github: 'https://github.com/Yodasama',
	email: 'yidaaa2269@163.com',
};

const projects = [
	{
		name: 'FedEdgeSim',
		description: '面向边缘场景的层次化联邦学习实验与仿真框架。',
		href: 'https://github.com/Yodasama',
		categories: ['agent', 'development'],
	},
	{
		name: 'Research Notes',
		description: '整理论文阅读、实验记录和工程复盘的知识库。',
		href: '/blog',
		categories: ['security'],
	},
	{
		name: 'Blog System',
		description: '基于 Astro、GitHub 与 Cloudflare Pages 的个人博客。',
		href: '/blog',
		categories: ['development'],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page">
		<div class="site-shell">
			<aside class="profile-panel" aria-label="个人信息">
				<div class="profile-main">
					<img class="avatar" src="/images/panda.JPG" width="180" height="180" alt={`${profile.name} avatar`} />
					<h1>{profile.name}</h1>
					<p>{profile.role}</p>
				</div>

				<section class="panel-section">
					<h2>About Me</h2>
					<p>{profile.intro}</p>
				</section>

				<section class="panel-section">
					<h2>Focus</h2>
					<ul class="focus-list">
						{
							focusCategories.map((category) => (
								<li>
									<button
										class="focus-button"
										type="button"
										data-filter={category.slug}
									>
										<span>{category.label}</span>
									</button>
								</li>
							))
						}
					</ul>
				</section>

				<section class="panel-section connect-section">
					<h2>Connect</h2>
					<div class="contact-list">
						<a href={profile.github} target="_blank" rel="noreferrer">
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path
										d="M12 2.5a9.5 9.5 0 0 0-3 18.52c.48.08.66-.2.66-.46v-1.7c-2.7.6-3.27-1.16-3.27-1.16-.44-1.12-1.08-1.42-1.08-1.42-.88-.6.07-.6.07-.6.98.07 1.5 1.02 1.5 1.02.88 1.5 2.3 1.06 2.86.8.09-.64.34-1.06.62-1.3-2.16-.25-4.43-1.08-4.43-4.8 0-1.06.38-1.93 1-2.61-.1-.25-.43-1.24.1-2.58 0 0 .82-.26 2.67 1a9.2 9.2 0 0 1 4.86 0c1.85-1.26 2.66-1 2.66-1 .54 1.34.2 2.33.1 2.58.63.68 1 1.55 1 2.61 0 3.73-2.27 4.55-4.44 4.79.35.3.67.9.67 1.82v2.7c0 .26.17.55.67.46A9.5 9.5 0 0 0 12 2.5Z"
									/>
								</svg>
							</span>
							<span>
								<strong>GitHub</strong>
								<small>github.com/Yodasama</small>
							</span>
						</a>
						<a href={`mailto:${profile.email}`}>
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path d="M4 6.5h16v11H4z" />
									<path d="m4 7 8 6 8-6" />
								</svg>
							</span>
							<span>
								<strong>Email</strong>
								<small>{profile.email}</small>
							</span>
						</a>
					</div>
				</section>
			</aside>

			<main class="content-area">
				<nav class="top-nav" aria-label="主导航">
					<div class="nav-links">
						<a class="active" href="/" data-home-filter>Home</a>
						<a href="/blog">Articles</a>
						<a href="#projects">Projects</a>
						<a href="/about">About</a>
					</div>
					<div class="nav-tools">
						<button class="theme-toggle" type="button" aria-label="切换明暗主题">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="M12 3v2" />
								<path d="M12 19v2" />
								<path d="m4.22 4.22 1.42 1.42" />
								<path d="m18.36 18.36 1.42 1.42" />
								<path d="M3 12h2" />
								<path d="M19 12h2" />
								<path d="m4.22 19.78 1.42-1.42" />
								<path d="m18.36 5.64 1.42-1.42" />
								<circle cx="12" cy="12" r="4" />
							</svg>
						</button>
						<form class="search-form" action="/blog" method="get" role="search">
							<label class="sr-only" for="site-search">搜索文章</label>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="m21 21-4.35-4.35" />
								<circle cx="11" cy="11" r="7" />
							</svg>
							<input id="site-search" name="q" type="search" placeholder="Search articles" />
						</form>
					</div>
				</nav>

				<section class="hero-card" aria-labelledby="hero-title">
					<Image class="hero-image" src={HeroImage} width={1200} height={675} alt="" loading="eager" />
					<div class="hero-overlay">
						<p class="eyebrow">Digital Garden</p>
						<h2 id="hero-title">记录系统、学习和工程实践中的长期思考。</h2>
					</div>
				</section>

				<div class="content-grid">
					<section class="card recent-card" aria-labelledby="recent-title">
						<div class="section-heading">
							<div>
								<h2 id="recent-title">Recent Articles</h2>
								<p data-filter-label>Latest</p>
							</div>
							<a href="/blog">View all</a>
						</div>
						<div class="article-list">
							{
								homePosts.map((post) => (
									<a
										class="article-item"
										href={`/blog/${post.id}/`}
										data-categories={post.categories.join(' ')}
									>
										<div>
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<div class="article-meta">
												<span>Notes</span>
												<span>
													<FormattedDate date={post.data.pubDate} />
												</span>
												<span>6 min read</span>
											</div>
										</div>
									</a>
								))
							}
						</div>
						<p class="empty-state" data-empty-state="articles">这个分类下暂时还没有文章。</p>
					</section>

					<section class="card projects-card" id="projects" aria-labelledby="projects-title">
						<div class="section-heading">
							<div>
								<h2 id="projects-title">Featured Projects</h2>
								<p data-filter-label>Latest</p>
							</div>
							<a href={profile.github} target="_blank" rel="noreferrer">View all</a>
						</div>
						<div class="project-list">
							{
								projects.map((project) => (
									<a
										class="project-item"
										href={project.href}
										target="_blank"
										rel="noreferrer"
										data-categories={project.categories.join(' ')}
									>
										<span class="project-icon" aria-hidden="true">
											<svg viewBox="0 0 24 24">
												<path d="m12 3 8 4.5-8 4.5-8-4.5L12 3Z" />
												<path d="m20 12-8 4.5L4 12" />
												<path d="m20 16.5-8 4.5-8-4.5" />
											</svg>
										</span>
										<span>
											<strong>{project.name}</strong>
											<small>{project.description}</small>
										</span>
									</a>
								))
							}
						</div>
						<p class="empty-state" data-empty-state="projects">这个分类下暂时还没有项目。</p>
					</section>
				</div>
			</main>
		</div>

		<script>
			const themeButton = document.querySelector('.theme-toggle');
			const savedTheme = localStorage.getItem('theme');

			if (savedTheme === 'dark') {
				document.body.classList.add('dark-mode');
			}

			themeButton?.addEventListener('click', () => {
				document.body.classList.toggle('dark-mode');
				localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
			});

			const filterButtons = [...document.querySelectorAll('.focus-button')];
			const homeFilter = document.querySelector('[data-home-filter]');
			const filterLabels = document.querySelectorAll('[data-filter-label]');
			const articleItems = [...document.querySelectorAll('.article-item')];
			const projectItems = [...document.querySelectorAll('.project-item')];
			const emptyArticles = document.querySelector('[data-empty-state="articles"]');
			const emptyProjects = document.querySelector('[data-empty-state="projects"]');

			function applyFilter(slug) {
				const activeButton = filterButtons.find((button) => button.dataset.filter === slug);
				const activeSlug = activeButton?.dataset.filter ?? 'all';
				const activeLabel = activeButton?.textContent?.trim() ?? 'Latest';

				filterButtons.forEach((button) => {
					button.classList.toggle('active', button.dataset.filter === activeSlug);
				});
				homeFilter?.classList.toggle('active', activeSlug === 'all');

				filterLabels.forEach((label) => {
					label.textContent = activeLabel;
				});

				const showItem = (item) =>
					activeSlug === 'all' || (item.dataset.categories ?? '').split(' ').includes(activeSlug);
				const visibleArticles = articleItems.filter(showItem);
				const visibleProjects = projectItems.filter(showItem);

				articleItems.forEach((item) => {
					item.hidden = !showItem(item);
				});
				projectItems.forEach((item) => {
					item.hidden = !showItem(item);
				});

				if (emptyArticles) emptyArticles.hidden = visibleArticles.length > 0;
				if (emptyProjects) emptyProjects.hidden = visibleProjects.length > 0;

				const url = new URL(window.location.href);
				if (activeSlug === 'all') {
					url.searchParams.delete('focus');
				} else {
					url.searchParams.set('focus', activeSlug);
				}
				window.history.replaceState({}, '', url);
			}

			homeFilter?.addEventListener('click', (event) => {
				event.preventDefault();
				applyFilter('all');
			});

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => applyFilter(button.dataset.filter ?? 'all'));
			});

			applyFilter(new URLSearchParams(window.location.search).get('focus') ?? 'all');
		</script>
	</body>
</html>

<style>
	:global(body.home-page) {
		min-height: 100vh;
		background:
			radial-gradient(circle at 78% 8%, rgba(72, 122, 255, 0.12), transparent 34rem),
			linear-gradient(90deg, #f5f7fb 0, #f5f7fb 19.5rem, #ffffff 19.5rem);
		color: #111827;
		font-size: 16px;
		line-height: 1.5;
		transition:
			background 180ms ease,
			color 180ms ease;
	}

	:global(body.home-page.dark-mode) {
		background:
			radial-gradient(circle at 78% 8%, rgba(96, 165, 250, 0.16), transparent 34rem),
			linear-gradient(90deg, #0f172a 0, #0f172a 19.5rem, #111827 19.5rem);
		color: #e5e7eb;
	}

	:global(body.home-page a) {
		color: inherit;
		text-decoration: none;
	}

	.site-shell,
	.site-shell * {
		box-sizing: border-box;
	}

	.site-shell {
		display: grid;
		grid-template-columns: 19.5rem minmax(0, 1fr);
		min-height: 100svh;
	}

	.profile-panel {
		position: sticky;
		top: 0;
		display: flex;
		flex-direction: column;
		gap: 1.35rem;
		height: 100svh;
		padding: 2rem;
		border-right: 1px solid rgba(148, 163, 184, 0.22);
		overflow: clip;
	}

	.profile-main {
		text-align: center;
	}

	.avatar {
		width: 7.5rem;
		height: 7.5rem;
		margin: 0 auto 1rem;
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 999px;
		box-shadow: 0 20px 54px rgba(15, 23, 42, 0.18);
		object-fit: cover;
		object-position: center;
	}

	.profile-main h1 {
		margin: 0;
		color: #030712;
		font-size: 1.55rem;
		line-height: 1.1;
	}

	.profile-main p,
	.panel-section p,
	.article-item p,
	.project-item small {
		color: #4b5563;
	}

	.profile-main p {
		margin: 0.7rem 0 0;
		font-size: 0.92rem;
	}

	.panel-section {
		padding-top: 1.15rem;
		border-top: 1px solid rgba(148, 163, 184, 0.28);
	}

	.connect-section {
		margin-top: auto;
	}

	.panel-section h2 {
		margin: 0 0 0.65rem;
		color: #6b7280;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.panel-section p {
		margin: 0;
		font-size: 0.88rem;
	}

	.focus-list,
	.contact-list {
		display: grid;
		gap: 0.72rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.contact-list a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #111827;
		font-size: 0.88rem;
	}

	.contact-icon,
	.theme-toggle,
	.search-form svg,
	.project-icon {
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		color: #4b5563;
	}

	.contact-icon svg,
	.theme-toggle svg,
	.search-form svg,
	.project-icon svg {
		width: 1.05rem;
		height: 1.05rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.focus-button {
		display: flex;
		align-items: center;
		width: 100%;
		min-height: 2.35rem;
		justify-content: flex-start;
		padding: 0 0.7rem;
		border: 1px solid transparent;
		border-radius: 0.8rem;
		background: transparent;
		color: #111827;
		cursor: pointer;
		font: inherit;
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.focus-button:hover,
	.focus-button.active {
		border-color: rgba(209, 213, 219, 0.78);
		background: rgba(255, 255, 255, 0.74);
		transform: translateX(2px);
	}

	.focus-button:focus {
		outline: none;
	}

	.focus-button:focus-visible {
		outline: 2px solid #2563eb;
		outline-offset: 2px;
	}

	.contact-list a {
		border-radius: 0.75rem;
		transition:
			background 180ms ease,
			transform 180ms ease;
	}

	.contact-list a:hover {
		background: rgba(255, 255, 255, 0.66);
		transform: translateX(2px);
	}

	.contact-list strong,
	.contact-list small {
		display: block;
	}

	.contact-list small {
		color: #6b7280;
		font-size: 0.78rem;
	}

	.content-area {
		display: grid;
		grid-template-rows: 2.55rem minmax(10.5rem, 0.7fr) minmax(23.5rem, 1.45fr);
		gap: 0.9rem;
		width: 100%;
		max-width: 78rem;
		height: 100svh;
		margin: 0 auto;
		padding: 1rem 2rem 1.25rem;
		overflow: hidden;
	}

	.top-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-width: 0;
	}

	.nav-links {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.65rem;
		min-width: 0;
	}

	.nav-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.35rem;
		padding: 0 0.95rem;
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 700;
		transition:
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-links a.active,
	.nav-links a:hover {
		background: rgba(243, 244, 246, 0.94);
		box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.12);
	}

	.nav-tools {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		flex: 0 0 auto;
	}

	.theme-toggle,
	.search-form {
		border: 1px solid rgba(209, 213, 219, 0.86);
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
	}

	.theme-toggle {
		width: 2.35rem;
		height: 2.35rem;
		padding: 0;
		border-radius: 999px;
		cursor: pointer;
	}

	.search-form {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		width: clamp(12rem, 20vw, 18rem);
		height: 2.35rem;
		padding: 0 0.85rem;
		border-radius: 999px;
	}

	.search-form input {
		width: 100%;
		min-width: 0;
		border: 0;
		outline: 0;
		background: transparent;
		color: #111827;
		font: inherit;
		font-size: 0.86rem;
	}

	.search-form input::placeholder {
		color: #9ca3af;
	}

	.hero-card,
	.card {
		border: 1px solid rgba(226, 232, 240, 0.92);
		border-radius: 1.35rem;
		background: rgba(255, 255, 255, 0.86);
		box-shadow: 0 22px 80px rgba(15, 23, 42, 0.06);
	}

	.hero-card {
		position: relative;
		background: #0f172a;
		min-height: 0;
		overflow: hidden;
	}

	.hero-card img {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		border-radius: 0;
		object-fit: cover;
		object-position: center 58%;
		filter: saturate(0.96) contrast(1.02);
	}

	.hero-card::after {
		position: absolute;
		inset: 0;
		content: '';
		background: linear-gradient(90deg, rgba(2, 6, 23, 0.52), rgba(2, 6, 23, 0.16) 42%, transparent 68%);
	}

	.hero-overlay {
		position: absolute;
		left: clamp(1.2rem, 3vw, 2.4rem);
		bottom: clamp(1.2rem, 3vw, 2.2rem);
		z-index: 1;
		max-width: 30rem;
	}

	.eyebrow {
		display: inline-flex;
		margin: 0 0 0.65rem;
		padding: 0.42rem 0.78rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.86);
		color: #111827;
		font-size: 0.78rem;
		font-weight: 800;
	}

	.hero-overlay h2 {
		margin: 0;
		color: #ffffff;
		font-size: clamp(1.45rem, 2.5vw, 2.35rem);
		line-height: 1.08;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.85fr);
		gap: 1rem;
		height: 100%;
		min-height: 0;
	}

	.card {
		display: flex;
		flex-direction: column;
		min-height: 0;
		padding: 1rem 1.05rem;
		overflow: hidden;
	}

	.section-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.62rem;
	}

	.section-heading h2 {
		margin: 0;
		font-size: 1rem;
	}

	.section-heading p {
		margin: 0.18rem 0 0;
		color: #64748b;
		font-size: 0.74rem;
		font-weight: 700;
	}

	.section-heading a {
		color: #4b5563;
		font-size: 0.82rem;
	}

	.article-list,
	.project-list {
		display: grid;
		flex: 1;
		align-content: start;
		gap: 0.48rem;
		min-height: 0;
	}

	.project-list {
		grid-auto-rows: 1fr;
	}

	.article-item {
