---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import FallbackArticleImage from '../assets/blog-placeholder-5.jpg';
import HeroTexture from '../assets/blog-placeholder-2.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const profile = {
	name: 'Yida',
	role: 'Software Engineer & Research Explorer',
	intro:
		'专注于构建可靠、可扩展、易理解的系统，也记录工程实践、机器学习和个人研究中的思考。',
	focus: ['Federated Learning', 'Distributed Systems', 'Machine Learning', 'Cloud & Edge Computing'],
	github: 'https://github.com/your-github',
	email: 'your.email@example.com',
};

const projects = [
	{
		name: 'FedEdgeSim',
		description: '面向边缘场景的层次化联邦学习实验与仿真框架。',
		href: 'https://github.com/your-github',
		tone: 'blue',
	},
	{
		name: 'Research Notes',
		description: '整理论文阅读、实验记录和工程复盘的知识库。',
		href: '/blog',
		tone: 'green',
	},
];

const categories = [
	['Machine Learning', 12],
	['Federated Learning', 10],
	['System Design', 8],
	['Cloud & Edge', 6],
	['Dev Notes', 5],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page">
		<div class="site-shell">
			<aside class="profile-panel" aria-label="个人信息">
				<div class="profile-main">
					<div class="avatar" aria-hidden="true">
						<span>Y</span>
					</div>
					<h1>{profile.name}<span class="status-dot" aria-hidden="true"></span></h1>
					<p>{profile.role}</p>
				</div>

				<div class="panel-section">
					<h2>About Me</h2>
					<p>{profile.intro}</p>
				</div>

				<div class="panel-section">
					<h2>Focus</h2>
					<ul class="focus-list">
						{
							profile.focus.map((item) => (
								<li>
									<span class="mini-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24">
											<path d="M12 3.5 20 8v8l-8 4.5L4 16V8l8-4.5Z" />
											<path d="M12 12 20 8" />
											<path d="M12 12v8.5" />
											<path d="M12 12 4 8" />
										</svg>
									</span>
									{item}
								</li>
							))
						}
					</ul>
				</div>

				<div class="panel-section">
					<h2>Connect</h2>
					<div class="contact-list">
						<a href={profile.github} target="_blank" rel="noreferrer">
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path
										d="M12 2.5a9.5 9.5 0 0 0-3 18.52c.48.08.66-.2.66-.46v-1.7c-2.7.6-3.27-1.16-3.27-1.16-.44-1.12-1.08-1.42-1.08-1.42-.88-.6.07-.6.07-.6.98.07 1.5 1.02 1.5 1.02.88 1.5 2.3 1.06 2.86.8.09-.64.34-1.06.62-1.3-2.16-.25-4.43-1.08-4.43-4.8 0-1.06.38-1.93 1-2.61-.1-.25-.43-1.24.1-2.58 0 0 .82-.26 2.67 1a9.2 9.2 0 0 1 4.86 0c1.85-1.26 2.66-1 2.66-1 .54 1.34.2 2.33.1 2.58.63.68 1 1.55 1 2.61 0 3.73-2.27 4.55-4.44 4.79.35.3.67.9.67 1.82v2.7c0 .26.17.55.67.46A9.5 9.5 0 0 0 12 2.5Z"
									/>
								</svg>
							</span>
							<span>
								<strong>GitHub</strong>
								<small>github.com/your-github</small>
							</span>
						</a>
						<a href={`mailto:${profile.email}`}>
							<span class="contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24">
									<path d="M4 6.5h16v11H4z" />
									<path d="m4 7 8 6 8-6" />
								</svg>
							</span>
							<span>
								<strong>Email</strong>
								<small>{profile.email}</small>
							</span>
						</a>
					</div>
				</div>
			</aside>

			<main class="content-area">
				<nav class="top-nav" aria-label="主导航">
					<a class="brand" href="/" aria-label="返回首页">YD</a>
					<div class="nav-links">
						<a class="active" href="/">Home</a>
						<a href="/blog">Articles</a>
						<a href="/blog">Notes</a>
						<a href="#projects">Projects</a>
						<a href="/about">About</a>
					</div>
					<a class="search-button" href="/blog" aria-label="搜索文章">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="m21 21-4.35-4.35" />
							<circle cx="11" cy="11" r="7" />
						</svg>
					</a>
				</nav>

				<section class="hero-card" aria-labelledby="hero-title">
					<div class="hero-copy">
						<p class="eyebrow">Hi, I'm {profile.name}</p>
						<h2 id="hero-title">Building reliable and intelligent systems for thoughtful engineering.</h2>
						<p>
							这里是我的数字花园，记录系统设计、联邦学习、工程实践和长期学习中的有效方法。
						</p>
						<div class="hero-actions">
							<a class="primary-button" href="/blog">Explore Articles</a>
							<a class="secondary-button" href="/about">About Me</a>
						</div>
					</div>
					<div class="hero-visual" aria-hidden="true">
						<Image src={HeroTexture} width={760} height={430} alt="" />
						<div class="mountain-layer mountain-back"></div>
						<div class="mountain-layer mountain-front"></div>
					</div>
				</section>

				<div class="content-grid">
					<section class="card recent-card" aria-labelledby="recent-title">
						<div class="section-heading">
							<h2 id="recent-title">Recent Articles</h2>
							<a href="/blog">View all</a>
						</div>
						<div class="article-list">
							{
								posts.map((post) => (
									<a class="article-item" href={`/blog/${post.id}/`}>
										<div class="article-thumb">
											<Image
												width={160}
												height={120}
												src={post.data.heroImage ?? FallbackArticleImage}
												alt=""
											/>
										</div>
										<div>
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<div class="article-meta">
												<span>Notes</span>
												<span>
													<FormattedDate date={post.data.pubDate} />
												</span>
												<span>6 min read</span>
											</div>
										</div>
									</a>
								))
							}
						</div>
					</section>

					<div class="side-stack">
						<section class="card projects-card" id="projects" aria-labelledby="projects-title">
							<div class="section-heading">
								<h2 id="projects-title">Featured Projects</h2>
								<a href={profile.github} target="_blank" rel="noreferrer">View all</a>
							</div>
							<div class="project-list">
								{
									projects.map((project) => (
										<article class="project-item">
											<div class={`project-icon ${project.tone}`} aria-hidden="true">
												<svg viewBox="0 0 24 24">
													<path d="m12 3 8 4.5-8 4.5-8-4.5L12 3Z" />
													<path d="m20 12-8 4.5L4 12" />
													<path d="m20 16.5-8 4.5-8-4.5" />
												</svg>
											</div>
											<div>
												<h3>{project.name}</h3>
												<p>{project.description}</p>
												<a class="github-button" href={project.href} target="_blank" rel="noreferrer">
													View on GitHub
													<svg viewBox="0 0 24 24" aria-hidden="true">
														<path d="M7 17 17 7" />
														<path d="M8 7h9v9" />
													</svg>
												</a>
											</div>
										</article>
									))
								}
							</div>
						</section>

						<section class="card categories-card" aria-labelledby="categories-title">
							<div class="section-heading plain">
								<h2 id="categories-title">Categories</h2>
							</div>
							<ul>
								{
									categories.map(([name, count]) => (
										<li>
											<span>{name}</span>
											<strong>{count}</strong>
										</li>
									))
								}
							</ul>
						</section>
					</div>
				</div>

				<section class="quote-card" aria-label="个人格言">
					<div>
						<span aria-hidden="true">“</span>
						<p>Simplicity is the ultimate sophistication.</p>
						<small>Leonardo da Vinci</small>
					</div>
				</section>
			</main>
		</div>
	</body>
</html>

<style>
	:global(body.home-page) {
		min-height: 100vh;
		background:
			radial-gradient(circle at 72% 10%, rgba(72, 122, 255, 0.12), transparent 32rem),
			linear-gradient(90deg, #f5f7fb 0, #f5f7fb 19.5rem, #ffffff 19.5rem);
		color: #111827;
		font-size: 16px;
		line-height: 1.5;
	}

	:global(body.home-page a) {
		color: inherit;
		text-decoration: none;
	}

	.site-shell,
	.site-shell * {
		box-sizing: border-box;
	}

	.site-shell {
		display: grid;
		grid-template-columns: 19.5rem minmax(0, 1fr);
		min-height: 100svh;
	}

	.profile-panel {
		position: sticky;
		top: 0;
		display: flex;
		flex-direction: column;
		gap: 2rem;
		height: 100svh;
		padding: 2rem 2rem 1.4rem;
		border-right: 1px solid rgba(148, 163, 184, 0.22);
		overflow-y: auto;
	}

	.profile-main {
		text-align: center;
	}

	.avatar {
		display: grid;
		place-items: center;
		width: 8.25rem;
		height: 8.25rem;
		margin: 0 auto 1rem;
		border: 1px solid rgba(255, 255, 255, 0.7);
		border-radius: 999px;
		background:
			linear-gradient(145deg, rgba(15, 23, 42, 0.12), rgba(255, 255, 255, 0.08)),
			radial-gradient(circle at 30% 22%, #dbeafe, #64748b 48%, #0f172a 100%);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
		color: #fff;
		font-size: 3.4rem;
		font-weight: 700;
	}

	.profile-main h1 {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin: 0;
		font-size: 1.55rem;
		line-height: 1.1;
	}

	.status-dot {
		width: 0.65rem;
		height: 0.65rem;
		border-radius: 999px;
		background: #3b82f6;
		box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.13);
	}

	.profile-main p,
	.panel-section p,
	.article-item p,
	.project-item p {
		color: #4b5563;
	}

	.profile-main p {
		margin: 0.7rem 0 0;
		font-size: 0.95rem;
	}

	.panel-section {
		padding-top: 1.2rem;
		border-top: 1px solid rgba(148, 163, 184, 0.28);
	}

	.panel-section h2 {
		margin: 0 0 0.9rem;
		color: #6b7280;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.panel-section p {
		margin: 0;
		font-size: 0.92rem;
	}

	.focus-list,
	.contact-list,
	.categories-card ul {
		display: grid;
		gap: 0.95rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.focus-list li,
	.contact-list a {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		color: #111827;
		font-size: 0.9rem;
	}

	.mini-icon,
	.contact-icon {
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		color: #4b5563;
	}

	.mini-icon svg,
	.contact-icon svg,
	.search-button svg,
	.project-icon svg,
	.github-button svg {
		width: 1.15rem;
		height: 1.15rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.contact-list a {
		border-radius: 0.75rem;
		transition:
			background 180ms ease,
			transform 180ms ease;
	}

	.contact-list a:hover {
		background: rgba(255, 255, 255, 0.66);
		transform: translateX(2px);
	}

	.contact-list strong,
	.contact-list small {
		display: block;
	}

	.contact-list small {
		color: #6b7280;
		font-size: 0.8rem;
	}

	.content-area {
		width: 100%;
		max-width: 78rem;
		margin: 0 auto;
		padding: 1rem 2rem 1.25rem;
	}

	.top-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.brand {
		font-size: 1.8rem;
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.nav-links a,
	.search-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.45rem;
		border-radius: 999px;
		font-size: 0.92rem;
		font-weight: 700;
		transition:
			background 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.nav-links a {
		padding: 0 1rem;
	}

	.nav-links a.active,
	.nav-links a:hover,
	.search-button:hover {
		background: rgba(243, 244, 246, 0.94);
		box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.12);
	}

	.search-button {
		width: 2.45rem;
	}

	.hero-card,
	.card,
	.quote-card {
		border: 1px solid rgba(226, 232, 240, 0.92);
		border-radius: 1.4rem;
		background: rgba(255, 255, 255, 0.86);
		box-shadow: 0 22px 80px rgba(15, 23, 42, 0.06);
	}

	.hero-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(18rem, 0.9fr) minmax(20rem, 1.1fr);
		min-height: 15rem;
		overflow: hidden;
	}

	.hero-copy {
		position: relative;
		z-index: 2;
		padding: 2rem;
	}

	.eyebrow {
		display: inline-flex;
		margin: 0 0 0.9rem;
		padding: 0.55rem 0.9rem;
		border-radius: 1rem;
		background: rgba(243, 244, 246, 0.92);
		color: #111827;
		font-size: 0.9rem;
		font-weight: 800;
	}

	.hero-copy h2 {
		max-width: 34rem;
		margin: 0;
		color: #020617;
		font-size: clamp(1.85rem, 2.4vw, 2.55rem);
		line-height: 1.04;
	}

	.hero-copy > p:not(.eyebrow) {
		max-width: 29rem;
		margin: 0.9rem 0 0;
		color: #4b5563;
		font-size: 1rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.15rem;
	}

	.primary-button,
	.secondary-button,
	.github-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.7rem;
		border-radius: 0.8rem;
		font-size: 0.88rem;
		font-weight: 800;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease;
	}

	.primary-button {
		padding: 0 1.25rem;
		background: #050505;
		color: #fff;
		box-shadow: 0 12px 24px rgba(0, 0, 0, 0.16);
	}

	.secondary-button,
	.github-button {
		padding: 0 1.15rem;
		border: 1px solid rgba(209, 213, 219, 0.86);
		background: rgba(255, 255, 255, 0.88);
	}

	.primary-button:hover,
	.secondary-button:hover,
	.github-button:hover {
		transform: translateY(-1px);
		box-shadow: 0 12px 26px rgba(15, 23, 42, 0.12);
	}

	.hero-visual {
		position: relative;
		min-height: 15rem;
		overflow: hidden;
		background: linear-gradient(120deg, rgba(248, 250, 252, 0.86), rgba(219, 234, 254, 0.5));
	}

	.hero-visual img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border-radius: 0;
		object-fit: cover;
		opacity: 0.26;
		filter: saturate(0.65);
	}

	.hero-visual::after {
		position: absolute;
		inset: 0;
		content: '';
		background: linear-gradient(90deg, #fff 0%, rgba(255, 255, 255, 0.58) 24%, transparent 58%);
	}

	.mountain-layer {
		position: absolute;
		right: -2rem;
		bottom: 0;
		width: 82%;
		height: 62%;
		clip-path: polygon(0 100%, 18% 48%, 31% 64%, 48% 18%, 65% 56%, 76% 34%, 100% 100%);
	}

	.mountain-back {
		background: linear-gradient(145deg, rgba(203, 213, 225, 0.72), rgba(100, 116, 139, 0.16));
		transform: translateY(-2.3rem) scale(1.05);
	}

	.mountain-front {
		background: linear-gradient(145deg, rgba(71, 85, 105, 0.62), rgba(15, 23, 42, 0.34));
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(20rem, 0.95fr);
		gap: 1.25rem;
		margin-top: 1rem;
	}

	.card {
		padding: 1.25rem;
	}

	.section-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-heading h2 {
		margin: 0;
		font-size: 1.02rem;
	}

	.section-heading a {
		color: #4b5563;
		font-size: 0.82rem;
	}

	.article-list,
	.project-list,
	.side-stack {
		display: grid;
		gap: 0.9rem;
	}

	.article-item {
		display: grid;
		grid-template-columns: 5rem minmax(0, 1fr);
		gap: 0.95rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid rgba(226, 232, 240, 0.9);
		transition: transform 180ms ease;
	}

	.article-item:last-child {
		padding-bottom: 0;
		border-bottom: 0;
	}

	.article-item:hover {
		transform: translateX(2px);
	}

	.article-thumb {
		aspect-ratio: 1;
		overflow: hidden;
		border-radius: 0.7rem;
		background: #e5e7eb;
	}

	.article-thumb img {
		width: 100%;
		height: 100%;
		border-radius: 0;
		object-fit: cover;
	}

	.article-item h3,
	.project-item h3 {
		margin: 0;
		color: #0f172a;
		font-size: 1rem;
		line-height: 1.25;
	}

	.article-item p,
	.project-item p {
		margin: 0.35rem 0 0;
		font-size: 0.84rem;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 0.55rem;
		color: #6b7280;
		font-size: 0.75rem;
	}

	.article-meta span:first-child {
		padding: 0.1rem 0.55rem;
		border-radius: 999px;
		background: #f3f4f6;
		color: #4b5563;
	}

	.project-item {
		display: grid;
		grid-template-columns: 3.35rem minmax(0, 1fr);
		gap: 0.85rem;
	}

	.project-icon {
		display: grid;
		place-items: center;
		width: 3.35rem;
		height: 3.35rem;
		border-radius: 0.85rem;
	}

	.project-icon.blue {
		background: #dbeafe;
		color: #2563eb;
	}

	.project-icon.green {
		background: #dcfce7;
		color: #16a34a;
	}

	.github-button {
		gap: 0.55rem;
		min-height: 2.3rem;
		margin-top: 0.75rem;
		font-size: 0.78rem;
	}

	.categories-card ul {
		gap: 0.8rem;
	}

	.categories-card li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: #111827;
		font-size: 0.88rem;
	}

	.categories-card strong {
		color: #64748b;
		font-size: 0.84rem;
	}

	.quote-card {
		position: relative;
		margin-top: 1.25rem;
		padding: 1.35rem 1.6rem;
		overflow: hidden;
	}

	.quote-card::after {
		position: absolute;
		right: 0;
		bottom: 0;
		width: 18rem;
		height: 4rem;
		content: '';
		clip-path: polygon(0 100%, 18% 66%, 28% 82%, 44% 38%, 58% 72%, 70% 42%, 100% 100%);
		background: linear-gradient(135deg, rgba(148, 163, 184, 0.2), rgba(71, 85, 105, 0.42));
	}

	.quote-card div {
		position: relative;
		z-index: 1;
		display: grid;
