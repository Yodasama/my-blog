---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];
type Heading = {
	depth: number;
	slug: string;
	text: string;
};
type SecondarySection = {
	heading: Heading;
	children: Heading[];
};
type PrimarySection = {
	heading: Heading;
	children: SecondarySection[];
};

const {
	title,
	summary,
	date,
	description,
	pubDate,
	updatedDate,
	heroImage,
	headings = [],
	readerLayout = false,
} = Astro.props as Props & {
	description?: string;
	pubDate?: Date;
	headings?: Heading[];
	readerLayout?: boolean;
};
const metaDescription = summary ?? description ?? '';
const displayDate = date ?? pubDate;
const primarySections: PrimarySection[] = [];
let currentPrimary: PrimarySection | undefined;
let currentSecondary: SecondarySection | undefined;

for (const heading of headings) {
	if (heading.depth === 1) {
		currentPrimary = { heading, children: [] };
		currentSecondary = undefined;
		primarySections.push(currentPrimary);
		continue;
	}

	if (heading.depth === 2) {
		if (!currentPrimary) {
			currentPrimary = {
				heading: { depth: 1, slug: title.toLowerCase().replaceAll(' ', '-'), text: title },
				children: [],
			};
			primarySections.push(currentPrimary);
		}
		currentSecondary = { heading, children: [] };
		currentPrimary.children.push(currentSecondary);
		continue;
	}

	if ((heading.depth === 3 || heading.depth === 4) && currentSecondary) {
		currentSecondary.children.push(heading);
	}
}

const secondarySections = primarySections.flatMap((section) => section.children);
---

{
	readerLayout ? (
		<html lang="zh-CN" style="scroll-padding-top: 128px;">
			<head>
				<BaseHead title={title} description={metaDescription} />
				<style>
					:global(html) {
						scroll-padding-top: 128px;
						scroll-behavior: smooth;
					}
					:global(body) {
						margin: 0;
						background: #f6f8fb;
						color: #1f2937;
					}
					.reader-shell {
						min-height: 100vh;
					}
					.reader-topbar {
						position: sticky;
						top: 0;
						z-index: 20;
						display: flex;
						align-items: center;
						justify-content: space-between;
						height: 56px;
						padding: 0 24px;
						border-bottom: 1px solid #e5e7eb;
						background: rgba(255, 255, 255, 0.86);
						backdrop-filter: blur(18px);
					}
					.breadcrumb {
						display: flex;
						align-items: center;
						gap: 10px;
						min-width: 0;
						color: #667085;
						font-size: 0.9rem;
					}
					.breadcrumb a {
						color: #475467;
						text-decoration: none;
					}
					.breadcrumb-title {
						overflow: hidden;
						color: #111827;
						text-overflow: ellipsis;
						white-space: nowrap;
					}
					.topbar-link {
						display: inline-flex;
						align-items: center;
						height: 34px;
						padding: 0 12px;
						border: 1px solid #d9dee8;
						border-radius: 8px;
						color: #344054;
						font-size: 0.85rem;
						text-decoration: none;
						background: #fff;
					}
					.reader-grid {
						display: grid;
						grid-template-columns: minmax(210px, 248px) minmax(0, 1fr);
						min-height: calc(100vh - 57px);
					}
					.primary-toc {
						position: sticky;
						top: 57px;
						height: calc(100vh - 57px);
						overflow: auto;
						padding: 34px 18px 28px 26px;
						border-right: 1px solid #e5e7eb;
						background: #f3f5f8;
					}
					.toc-label {
						margin: 0 0 14px;
						color: #98a2b3;
						font-size: 0.72rem;
						font-weight: 700;
						letter-spacing: 0.08em;
						text-transform: uppercase;
					}
					.toc-list {
						display: flex;
						flex-direction: column;
						gap: 2px;
						margin: 0;
						padding: 0;
						list-style: none;
					}
					.primary-list {
						gap: 6px;
					}
					.primary-group {
						min-width: 0;
					}
					.primary-group details {
						border-radius: 10px;
					}
					.primary-group summary {
						display: flex;
						align-items: center;
						gap: 6px;
						min-height: 36px;
						padding: 0 6px;
						border-radius: 10px;
						cursor: pointer;
						list-style: none;
					}
					.primary-group summary::-webkit-details-marker {
						display: none;
					}
					.primary-group summary:hover {
						background: #fff;
					}
					.primary-marker {
						display: inline-flex;
						align-items: center;
						justify-content: center;
						width: 14px;
						height: 14px;
						color: #98a2b3;
						font-size: 0.72rem;
						transition: transform 0.16s ease;
					}
					.primary-group details[open] .primary-marker {
						transform: rotate(90deg);
					}
					.toc-list a {
						display: block;
						overflow: hidden;
						padding: 8px 10px;
						border-radius: 8px;
						color: #475467;
						font-size: 0.9rem;
						line-height: 1.35;
						text-decoration: none;
						text-overflow: ellipsis;
						white-space: nowrap;
					}
					.toc-list a:hover {
						background: #fff;
						color: #175cd3;
					}
					.primary-title {
						min-width: 0;
						flex: 1;
						padding-left: 0;
						color: #344054;
						font-weight: 650;
					}
					.child-toc-list {
						margin: 2px 0 4px 22px;
					}
					.child-toc-list a {
						color: #667085;
						font-size: 0.86rem;
					}
					.child-toc-list a.active {
						background: #fff;
						color: #175cd3;
						font-weight: 650;
					}
					.empty-toc {
						margin: 0;
						color: #98a2b3;
						font-size: 0.86rem;
						line-height: 1.6;
					}
					.reader-main {
						display: grid;
						box-sizing: border-box;
						width: 100%;
						grid-template-columns: minmax(120px, 170px) minmax(0, 860px);
						justify-content: center;
						gap: 26px;
						padding: 58px 28px 84px;
					}
					.secondary-toc {
						position: sticky;
						top: 92px;
						align-self: start;
						max-height: calc(100vh - 120px);
						overflow: auto;
						padding: 4px 0;
					}
					.secondary-toc .toc-list a {
						padding: 7px 10px;
						color: #667085;
						font-size: 0.84rem;
					}
					.secondary-toc .depth-4 a {
						padding-left: 22px;
						font-size: 0.8rem;
					}
					.secondary-panel[hidden],
					.secondary-placeholder[hidden] {
						display: none;
					}
					.post-card {
						min-width: 0;
						padding: 0 0 42px;
					}
					.post-header {
						margin-bottom: 30px;
					}
					.date {
						margin-bottom: 12px;
						color: #667085;
						font-size: 0.92rem;
					}
					.post-header h1 {
						margin: 0;
						color: #20242c;
						font-size: clamp(2.15rem, 4vw, 3.4rem);
						line-height: 1.12;
						letter-spacing: 0;
					}
					.summary {
						margin: 22px 0 0;
						padding: 14px 16px;
						border: 1px solid #d9dee8;
						border-radius: 8px;
						background: #fff;
						color: #667085;
						font-size: 0.96rem;
						line-height: 1.7;
					}
					.hero-image {
						margin: 26px 0;
					}
					.hero-image img {
						display: block;
						width: 100%;
						height: auto;
						border: 1px solid #e5e7eb;
						border-radius: 10px;
					}
					.prose {
						color: #2f3440;
						font-size: 1rem;
						line-height: 1.85;
					}
					.prose :global(h1),
					.prose :global(h2),
					.prose :global(h3),
					.prose :global(h4) {
						scroll-margin-top: 116px;
						color: #20242c;
						line-height: 1.3;
						letter-spacing: 0;
					}
					.prose :global(h1) {
						margin: 2.4rem 0 1rem;
						font-size: 2rem;
					}
					.prose :global(h2) {
						margin: 2.2rem 0 0.9rem;
						font-size: 1.55rem;
					}
					.prose :global(h3) {
						margin: 1.8rem 0 0.7rem;
						font-size: 1.22rem;
					}
					.prose :global(h4) {
						margin: 1.4rem 0 0.5rem;
						font-size: 1.05rem;
					}
					.prose :global(p),
					.prose :global(ul),
					.prose :global(ol),
					.prose :global(blockquote) {
						margin: 0 0 1rem;
					}
					.prose :global(a) {
						color: #175cd3;
						text-decoration-thickness: 1px;
						text-underline-offset: 3px;
					}
					.prose :global(blockquote) {
						padding: 12px 16px;
						border-left: 3px solid #98a2b3;
						border-radius: 0 8px 8px 0;
						background: #f8fafc;
						color: #475467;
					}
					.prose :global(pre) {
						overflow-x: auto;
						margin: 1.2rem 0;
						padding: 16px;
						border: 1px solid #d9dee8;
						border-radius: 10px;
						background: #111827;
						color: #f8fafc;
					}
					.prose :global(code) {
						padding: 0.15rem 0.35rem;
						border-radius: 5px;
						background: #eef2f7;
						color: #344054;
						font-size: 0.9em;
					}
					.prose :global(pre code) {
						padding: 0;
						background: transparent;
						color: inherit;
					}
					.prose :global(table) {
						display: block;
						width: 100%;
						overflow-x: auto;
						border-collapse: collapse;
					}
					.prose :global(th),
					.prose :global(td) {
						padding: 10px 12px;
						border: 1px solid #d9dee8;
					}
					@media (max-width: 1040px) {
						.reader-grid {
							grid-template-columns: 1fr;
						}
						.primary-toc {
							position: static;
							height: auto;
							border-right: 0;
							border-bottom: 1px solid #e5e7eb;
						}
						.reader-main {
							grid-template-columns: 1fr;
							padding: 34px 22px 64px;
						}
						.secondary-toc {
							position: static;
							max-height: none;
							padding-bottom: 12px;
							border-bottom: 1px solid #e5e7eb;
						}
					}
					@media (max-width: 640px) {
						.reader-topbar {
							padding: 0 14px;
						}
						.primary-toc {
							padding: 22px 14px;
						}
						.reader-main {
							padding: 26px 16px 56px;
						}
						.post-header h1 {
							font-size: 2rem;
						}
					}
				</style>
			</head>

			<body>
				<div class="reader-shell">
					<header class="reader-topbar">
						<div class="breadcrumb">
							<a href="/">Home</a>
							<span>/</span>
							<a href="/blog/">Articles</a>
							<span>/</span>
							<span class="breadcrumb-title">{title}</span>
						</div>
						<a class="topbar-link" href="/blog/">Back</a>
					</header>
					<div class="reader-grid">
						<aside class="primary-toc" aria-label="一级和二级目录">
							<p class="toc-label">Contents</p>
							{primarySections.length > 0 ? (
								<ol class="toc-list primary-list">
									{primarySections.map((section) => (
										<li class="primary-group">
											<details>
												<summary>
													<span class="primary-marker" aria-hidden="true">
														&gt;
													</span>
													<a class="primary-title" href={`#${section.heading.slug}`}>
														{section.heading.text}
													</a>
												</summary>
												{section.children.length > 0 && (
													<ol class="toc-list child-toc-list">
														{section.children.map((child) => (
															<li>
																<a
																	class="secondary-selector"
																	data-secondary-target={`section-${child.heading.slug}`}
																	href={`#${child.heading.slug}`}
																>
																	{child.heading.text}
																</a>
															</li>
														))}
													</ol>
												)}
											</details>
										</li>
									))}
								</ol>
							) : (
								<p class="empty-toc">这篇文章还没有一级或二级标题。</p>
							)}
						</aside>
						<main class="reader-main">
							<aside class="secondary-toc" aria-label="三级和四级目录">
								<p class="toc-label">Sections</p>
								{secondarySections.length > 0 ? (
									<>
										<div class="secondary-placeholder" data-secondary-empty></div>
										{secondarySections.map((section) => (
											<div
												class="secondary-panel"
												data-secondary-panel={`section-${section.heading.slug}`}
												hidden
											>
												{section.children.length > 0 ? (
													<ol class="toc-list">
														{section.children.map((heading) => (
															<li class={`depth-${heading.depth}`}>
																<a href={`#${heading.slug}`}>{heading.text}</a>
															</li>
														))}
													</ol>
												) : (
													<p class="empty-toc">这个二级标题下暂无三四级标题。</p>
												)}
											</div>
										))}
									</>
								) : (
									<p class="empty-toc">暂无三级或四级标题。</p>
								)}
							</aside>
							<article class="post-card">
								<header class="post-header">
									<div class="date">
										{displayDate && <FormattedDate date={displayDate} />}
										{updatedDate && (
											<span>
												{' '}
												· Updated <FormattedDate date={updatedDate} />
											</span>
										)}
									</div>
									<h1>{title}</h1>
									{metaDescription && <p class="summary">{metaDescription}</p>}
									{heroImage && (
										<div class="hero-image">
											<Image width={1020} height={510} src={heroImage} alt="" />
										</div>
									)}
								</header>
								<div class="prose">
									<slot />
								</div>
							</article>
						</main>
					</div>
				</div>
				<script>
					const selectors = Array.from(document.querySelectorAll('.secondary-selector'));
					const panels = Array.from(document.querySelectorAll('.secondary-panel'));
					const placeholder = document.querySelector('[data-secondary-empty]');
					const readerLinks = Array.from(
						document.querySelectorAll('.primary-toc a[href^="#"], .secondary-toc a[href^="#"]'),
					);
					const scrollOffset = 128;

					const showPanel = (panelId) => {
						const activePanel = panels.find((panel) => panel.getAttribute('data-secondary-panel') === panelId);

						panels.forEach((panel) => {
							panel.toggleAttribute('hidden', panel !== activePanel);
						});
						selectors.forEach((selector) => {
							selector.classList.toggle(
								'active',
								selector.getAttribute('data-secondary-target') === panelId,
							);
						});

						if (placeholder) {
							placeholder.toggleAttribute('hidden', Boolean(activePanel));
						}
					};

					const showPanelFromHash = () => {
						const slug = decodeURIComponent(window.location.hash.slice(1));
						if (!slug) return;

						const directSelector = selectors.find(
							(selector) => selector.getAttribute('href') === `#${slug}`,
						);
						if (directSelector) {
							showPanel(directSelector.getAttribute('data-secondary-target'));
							return;
						}

						const containingPanel = panels.find((panel) => panel.querySelector(`a[href="#${slug}"]`));
						if (containingPanel) {
							showPanel(containingPanel.getAttribute('data-secondary-panel'));
						}
					};

					const scrollToSlug = (slug) => {
						const target = document.getElementById(slug);
						if (!target) return;

						const top = target.getBoundingClientRect().top + window.scrollY - scrollOffset;
						window.scrollTo({ top: Math.max(top, 0), behavior: 'smooth' });
					};

					readerLinks.forEach((link) => {
						link.addEventListener('click', (event) => {
							const slug = decodeURIComponent(link.getAttribute('href').slice(1));
							event.preventDefault();

							if (link.classList.contains('secondary-selector')) {
								showPanel(link.getAttribute('data-secondary-target'));
							}

							window.history.pushState({}, '', `#${encodeURIComponent(slug)}`);
							scrollToSlug(slug);
						});
					});

					selectors.forEach((selector) => {
						selector.addEventListener('click', () => {
							showPanel(selector.getAttribute('data-secondary-target'));
						});
					});
					window.addEventListener('hashchange', showPanelFromHash);
					showPanelFromHash();
					if (window.location.hash) {
						window.setTimeout(() => {
							scrollToSlug(decodeURIComponent(window.location.hash.slice(1)));
						}, 0);
					}
				</script>
			</body>
		</html>
	) : (
		<html lang="en">
			<head>
				<BaseHead title={title} description={metaDescription} />
				<style>
					main {
						width: calc(100% - 2em);
						max-width: 100%;
						margin: 0;
					}
					.hero-image {
						width: 100%;
					}
					.hero-image img {
						display: block;
						margin: 0 auto;
						border-radius: 12px;
						box-shadow: var(--box-shadow);
					}
					.prose {
						width: 720px;
						max-width: calc(100% - 2em);
						margin: auto;
						padding: 1em;
						color: rgb(var(--gray-dark));
					}
					.title {
						margin-bottom: 1em;
						padding: 1em 0;
						text-align: center;
						line-height: 1;
					}
					.title h1 {
						margin: 0 0 0.5em 0;
					}
					.date {
						margin-bottom: 0.5em;
						color: rgb(var(--gray));
					}
					.last-updated-on {
						font-style: italic;
					}
				</style>
			</head>

			<body>
				<Header />
				<main>
					<article>
						<div class="hero-image">
							{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
						</div>
						<div class="prose">
							<div class="title">
								<div class="date">
									{displayDate && <FormattedDate date={displayDate} />}
									{updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
								<h1>{title}</h1>
								<hr />
							</div>
							<slot />
						</div>
					</article>
				</main>
				<Footer />
			</body>
		</html>
	)
}
