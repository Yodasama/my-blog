---
import type { Project } from '../../data/projects';

interface Props {
	project: Project;
	featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<article class:list={['project-card', { 'project-card-featured': featured }]} data-categories={project.categories.join('|')}>
	<div class="project-card-top">
		<div>
			<p class="project-kicker">{project.categories[0]}</p>
			<h3><a href={project.href}>{project.name}</a></h3>
		</div>
		<span class="project-status">{project.status}</span>
	</div>
	<p class="project-summary">{project.summary}</p>
	<p class="project-description">{project.description}</p>
	<div class="tech-pills" aria-label={`${project.name} tech stack`}>
		{project.tags.map((tag) => <span>{tag}</span>)}
	</div>
	<div class="project-links" aria-label={`${project.name} links`}>
		{project.links.map((link) => <a href={link.href}>{link.label}</a>)}
	</div>
	{
		featured && project.metrics && (
			<div class="project-metrics">
				{project.metrics.map((metric) => (
					<div>
						<strong>{metric.value}</strong>
						<span>{metric.label}</span>
					</div>
				))}
			</div>
		)
	}
</article>
